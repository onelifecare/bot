PORT=3000
WEBHOOK_PATH=/webhook/messenger

# Facebook
FB_VERIFY_TOKEN=replace_with_verify_token
FB_APP_SECRET=replace_with_app_secret
DASHBOARD_ADMIN_TOKEN=replace_with_dashboard_admin_token
STATIC_GREETING_AR=أهلاً بيك 👋 أنا معاك من فريق One Life Care، تحت أمرك.

# Google Sheets service account
GOOGLE_SHEET_ID=replace_with_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Tabs (keep defaults unless your sheet differs)
SHEET_PAGES_TAB=Pages
SHEET_BOTCONTROL_TAB=BotControl
SHEET_CHATCONTROL_TAB=ChatControl
SHEET_ACTION_LOG_TAB=Audit
SHEET_HANDOFFS_TAB=Handoffs

# AI / LLM provider
# Strategic direction: Gemini. Set BRAIN_PROVIDER=gemini for the intended path.
# Allowed values: mock | gemini | openai (legacy)
BRAIN_PROVIDER=mock
AI_SYSTEM_PROMPT=

# Gemini (intended provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (legacy compatibility layer — kept to avoid breaking existing setups)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_API_URL=
